// memory_simple.v
module memory(
    input clk,
    input [15:0] address,
    input [15:0] data_in,
    input write_en,
    input read_en,
    output reg [15:0] data_out
);

    // Small memory for testing
    reg [15:0] mem [0:15]; // 16 locations
    
    integer i;
    initial begin
        // Initialize all memory
        for (i = 0; i < 16; i = i + 1) begin
            mem[i] = 16'b0;
        end
        
        // SIMPLE TEST PROGRAM
        mem[0] = {`OP_LDI, `REG_X, 9'h005};  // LDI X, 5
        mem[1] = {`OP_LDI, `REG_Y, 9'h003};  // LDI Y, 3
        mem[2] = {`OP_MOV, `REG_X, 9'h000};  // MOV A, X
        mem[3] = {`OP_ADD, `REG_Y, 9'h000};  // ADD Y
        mem[4] = {`OP_BRA, 10'h004};         // BRA 4 (loop)
        
        data_out = 16'b0;
    end

    always @(posedge clk) begin
        if (write_en && address < 16) begin
            mem[address] <= data_in;
        end
    end

    always @(*) begin
        if (read_en && address < 16) begin
            data_out = mem[address];
        end else begin
            data_out = 16'b0;
        end
    end

endmodule